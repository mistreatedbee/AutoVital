## InsForge backend (required for API calls)
## Obtain from: insforge link + insforge metadata --json, or InsForge dashboard
VITE_INSFORGE_URL=
VITE_INSFORGE_ANON_KEY=

## System Admin allowlist (comma-separated emails)
## Users with these emails get full platform admin access after signup.
## Example: VITE_ADMIN_EMAILS=admin@company.com,system@company.com
VITE_ADMIN_EMAILS=

## Storage buckets (optional; defaults used if omitted)
## VITE_AVATARS_BUCKET=avatars
## VITE_VEHICLE_IMAGES_BUCKET=vehicle-images
## VITE_DOCUMENTS_BUCKET=vehicle-documents
